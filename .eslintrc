{
  "parser": "babel-eslint",
  "extends": "atomikui",
  "settings": {
    "import/resolver": {
      "alias": {
        "map": [
          ["@atomikui-core", "./node_modules/@atomikui/core/dist/components"]
        ]
      }
    }
  },
  "rules": {
    "react/jsx-filename-extension": [0, { "extensions": [".jsx"] }],
    "react/require-default-props": 0
  }
}
